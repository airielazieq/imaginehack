{
  "_comment": "Demo scenario telemetry patches (ARCHITECTURE.md §10.5). Each is applied on top of the workload's healthy baseline to flip it into an anomalous state. 'expected' fields are used by tests/validate_scenarios.py to confirm the deterministic pipeline still fires the intended issue/severity/execution_mode after data-derived thresholds (§6.11).",
  "scenarios": [
    {
      "scenario_id": "trigger_idle_dev_server",
      "title": "Idle Development Server",
      "target_workload": "wl-bim-processor-001",
      "patch": {
        "cpu_usage_percent": 3.2,
        "memory_usage_percent": 18.5,
        "runtime_hours_24h": 24,
        "request_count_24h": 120,
        "cost_24h": 57.6,
        "cost_30d_forecast": 1728.0,
        "energy_kwh_24h": 38.5,
        "carbon_kgco2e_24h": 21.7,
        "environment": "development",
        "workflow_criticality": "medium",
        "monitoring_enabled": true
      },
      "expected": {
        "issue_type": "idle_or_overprovisioned_workload",
        "issue_category": "cost_energy_carbon",
        "severity": "medium",
        "execution_mode": "auto_fix"
      }
    },
    {
