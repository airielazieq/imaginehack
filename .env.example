# Clover backend configuration — copy to .env and adjust as needed.
# All variables are optional; defaults are applied when unset.

# Path to the SQLite database file.
CLOVER_DB_PATH=backend/clover.db

# Comma-separated list of allowed CORS origins (frontend dev servers).
CLOVER_CORS_ORIGINS=http://localhost:5174,http://localhost:5173,http://localhost:3000

# Logging level: DEBUG | INFO | WARNING | ERROR
CLOVER_LOG_LEVEL=INFO
